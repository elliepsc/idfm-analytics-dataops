# Copy to .env and fill in the required values.
# Local authentication uses Application Default Credentials (ADC) only:
#   gcloud auth application-default login
# Do not create JSON keys and do not set GOOGLE_APPLICATION_CREDENTIALS locally.

# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west1

# BigQuery
BQ_DATASET_RAW=transport_raw
BQ_DATASET_STAGING=transport_staging
BQ_DATASET_CORE=transport_core
BQ_DATASET_BASE=transport
BQ_DATASET_ANALYTICS=transport_analytics

# Optional GCS buckets
GCS_BUCKET_BRONZE=<your-project-transport-bronze>
GCS_BUCKET_SILVER=<your-project-transport-silver>
GCS_BUCKET_RAW=<your-project-transport-raw>

# Source APIs
IDFM_BASE_URL=https://data.iledefrance-mobilites.fr/api/explore/v2.1
TRANSILIEN_BASE_URL=https://ressources.data.sncf.com/api/explore/v2.1
IDFM_API_KEY=<your_idfm_api_key_here> # https://data.iledefrance-mobilites.fr/api/explore/v2.1/console
PRIM_API_KEY=<your_prim_api_key_here> # https://prim.iledefrance-mobilites.fr/fr/ma-consommation-api


# Local environment
ENVIRONMENT=dev
AIRFLOW_HOST_PORT=8081
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
SLACK_WEBHOOK_CONN_ID=slack_webhook
SLACK_ALERT_CHANNEL="#data-alerts"
DBT_BIN=/home/airflow/.local/bin/dbt

# Optional override
# PROJECT_ROOT=/absolute/path/to/idfm-analytics-dataops
